# MCP Server Configuration

# Tenant ID to use (must match an entry in src/config/tenants.json)
TENANT_ID=internal

# Optional: Override API URL for the selected tenant
# API_URL=http://localhost:3002

# API Keys per Tenant (recommended)
# Pattern: TENANT_<TENANT_ID_UPPERCASE_WITH_UNDERSCORES>_API_KEY
# These take precedence over the global API_KEY and over values in tenants.json
TENANT_INTERNAL_API_KEY=
TENANT_INTERNAL_PROD_API_KEY=
# TENANT_CUSTOMER_APP_API_KEY=
# TENANT_CUSTOMER_READONLY_API_KEY=

# Optional: Global API key override (applies to the currently selected tenant)
# Lower priority than per-tenant keys above. Kept for backwards compatibility.
# API_KEY=your-api-key-here

# Logging Level (error, warn, info, debug)
LOG_LEVEL=info

# --- Rate limiter (Remote-MCP HTTP gateway, #5194) ---
# Redis backing the per-key rate limiter. Reuses the platform Redis env. With
# neither REDIS_URL nor REDIS_HOST set, rate limiting is OFF (no backing store).
# REDIS_URL=redis://localhost:6379          # full URL form; rediss:// enables TLS
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# Enforce TLS for the host/port form above (a remote Redis would otherwise run
# unencrypted). Not needed with a rediss:// REDIS_URL (TLS negotiated by the URL).
# REDIS_TLS=false
# Rate-limit knobs (defaults shown). MAX<=0 disables limiting entirely.
# MCP_RATE_LIMIT_MAX=120
# MCP_RATE_LIMIT_WINDOW_MS=60000
# MCP_RATE_LIMIT_PREFIX=mcp:ratelimit:
# Throttle for the Sentry alert on a sustained Redis outage (fail-open), ms.
# MCP_REDIS_ALERT_THROTTLE_MS=300000

# --- Multi-LLM playbook eval (#5208, CI nightly + dev->main PR only) ---
# Real-LLM eval of the MVP playbooks. A provider whose key is absent is SKIPPED
# (not failed); zero keys => gate is "inconclusive" (a skip, not a false pass).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Optional model overrides:
# ANTHROPIC_EVAL_MODEL=claude-sonnet-4-6
# OPENAI_EVAL_MODEL=gpt-4o
# Pass threshold as a fraction of pooled (case x provider) runs (default 0.8):
# EVAL_PASS_THRESHOLD=0.8
